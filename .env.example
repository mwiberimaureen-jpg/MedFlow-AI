# =====================================================
# MEDFLOW AI - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or .env to git!
# =====================================================

# =====================================================
# APPLICATION SETTINGS
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MedFlow AI

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# OPENROUTER AI API
# =====================================================
# Get from: https://openrouter.ai/keys
# Used for patient analysis (Sonnet) and QA checks (Haiku)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# INTASEND PAYMENT GATEWAY
# =====================================================
# Get from: https://dashboard.intasend.com/account/api-keys

# Test mode keys (use for development)
INTASEND_PUBLISHABLE_KEY=ISPubKey_test_xxxxxxxx
INTASEND_SECRET_KEY=ISSecKey_test_xxxxxxxx
INTASEND_WEBHOOK_SECRET=your-webhook-secret-here
INTASEND_ENVIRONMENT=sandbox

# Production keys (uncomment for production)
# INTASEND_PUBLISHABLE_KEY=ISPubKey_live_xxxxxxxx
# INTASEND_SECRET_KEY=ISSecKey_live_xxxxxxxx
# INTASEND_ENVIRONMENT=production

# =====================================================
# FIELD-LEVEL ENCRYPTION (HIPAA)
# =====================================================
# 32-byte hex key for AES-256-GCM encryption of PII fields.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this key, PII is stored in plain text (backwards-compatible).
FIELD_ENCRYPTION_KEY=

# =====================================================
# FIREBASE PHONE AUTH (OTP verification at signup)
# =====================================================
# Firebase handles SMS OTP delivery + verification. Free tier: 10K
# verifications/month (Kenya included).
#
# Setup:
#   1. Create a project at https://console.firebase.google.com
#   2. Enable Authentication -> Sign-in method -> Phone
#   3. Project settings -> General -> Add a Web app, copy these values
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

#   4. Project settings -> Service accounts -> Generate new private key.
#      Copy values from the downloaded JSON. The private key spans multiple
#      lines — keep the \n escapes literal (the server unescapes them).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# =====================================================
# SUBSCRIPTION PRICING (in KES - Kenyan Shillings)
# =====================================================
NEXT_PUBLIC_MONTHLY_PRICE=2000
NEXT_PUBLIC_CURRENCY=KES
NEXT_PUBLIC_TRIAL_DAYS=7
